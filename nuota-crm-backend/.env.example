# 数据库（psycopg v3 方言）
DATABASE_URL=postgresql+psycopg://jiuyi@localhost:5432/nuota_crm

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# 微信小程序
WX_APPID=CONFIG.WX_APPID
WX_SECRET=CONFIG.WX_SECRET

# 腾讯云人脸核身
TENCENT_SECRET_ID=CONFIG.TENCENT_SECRET_ID
TENCENT_SECRET_KEY=CONFIG.TENCENT_SECRET_KEY
TENCENT_FACE_GROUP=nuota_tata_members
TENCENT_REGION=ap-guangzhou

# 企微通知
WECOM_WEBHOOK=CONFIG.WECOM_WEBHOOK

# 应用配置
APP_NAME=nuota-crm-backend
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:5174

# 管理后台默认账号（首次启动自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# 上传目录
STATIC_DIR=/www/nuota-crm/static
UPLOAD_DIR=/www/nuota-crm/static/uploads
MAX_UPLOAD_BYTES=5242880

# 微信支付
WXPAY_SUB_MCH_ID=
WXPAY_SUB_APPID=
WXPAY_APIV3_KEY=
WXPAY_CERT_SERIAL=
WXPAY_CERT_DIR=/www/nuota-crm/certs
WXPAY_NOTIFY_URL=
WXPAY_SP_MCH_ID=
WXPAY_SP_APPID=
